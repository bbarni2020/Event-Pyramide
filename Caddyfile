{
    auto_https off
}

{$FRONTEND_HOST}:{$CADDY_PORT} {
    handle /api/* {
        reverse_proxy 127.0.0.1:{$PORT}
    }

    handle /auth/* {
        reverse_proxy 127.0.0.1:{$PORT}
    }

    handle {
        root * /srv/frontend/dist
        try_files {path} /index.html
        file_server
    }
}

{$API_HOST}:{$CADDY_PORT} {
    reverse_proxy 127.0.0.1:{$PORT}
}
